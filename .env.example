# Base de datos SQLite (ruta relativa al proyecto)
# Ruta relativa al directorio prisma/
DATABASE_URL="file:./dev.db"

# NextAuth (obligatorio en producción; generar: openssl rand -base64 32)
NEXTAUTH_SECRET=your-secret-at-least-32-chars
NEXTAUTH_URL=http://localhost:3000

# SMTP para envío de correos (recuperación de contraseña). Sin esto no se enviarán emails.
# SMTP_HOST=smtp.ejemplo.com
# SMTP_PORT=587
# SMTP_USER=tu-usuario
# SMTP_PASS=tu-contraseña
# SMTP_FROM=noreply@tudominio.com

# Copernicus Data Space (Sentinel-2 NDVI). Registro gratuito: https://dataspace.copernicus.eu/
# Tras registrarte, obtén tu Instance ID y pégalo aquí para habilitar el mapa de vegetación (NDVI).
# COPERNICUS_WMS_INSTANCE_ID=your-instance-id

# Opcional: para /api/copernicus/token (client credentials). Client ID y Secret en tu cuenta Copernicus.
# COPERNICUS_CLIENT_ID=your-client-id
# COPERNICUS_CLIENT_SECRET=your-client-secret

# Supabase (Doctor de Cultivos: crop_diagnoses + bucket diagnosis-images)
# NEXT_PUBLIC_SUPABASE_URL=https://xxx.supabase.co
# SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# OpenAI (análisis de imágenes del Doctor de Cultivos)
# OPENAI_API_KEY=sk-...
