# Copia a .env en el servidor (o define estas variables en tu plataforma).
# NO subas .env al repositorio.

NODE_ENV=production

# URL pública de la app (obligatorio NextAuth y enlaces de recuperación de contraseña)
NEXTAUTH_URL=https://tu-dominio.com
NEXTAUTH_SECRET=cambia-por-un-secreto-largo-openssl-rand-base64-32

# Base de datos
# — Docker (docker-compose de este repo): se fuerza SQLite en /data
DATABASE_URL=file:/data/prod.db
# — Servidor/VPS con SQLite en un único path persistente:
# DATABASE_URL=file:/var/lib/gestor-fincas/prod.db
# — Vercel / serverless: SQLite no es adecuado; usa PostgreSQL y cambia provider en schema.prisma
# DATABASE_URL=postgresql://usuario:clave@host:5432/gestor_fincas?schema=public

# Correo (obligatorio en producción para «olvidé contraseña»; en dev se usa Ethereal si falta)
SMTP_HOST=smtp.tu-proveedor.com
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=
SMTP_FROM="Cuaderno Campo <noreply@tudominio.com>"

# Opcionales (mapas, doctor de cultivos, etc.)
# COPERNICUS_WMS_INSTANCE_ID=
# COPERNICUS_CLIENT_ID=
# COPERNICUS_CLIENT_SECRET=
# NEXT_PUBLIC_SUPABASE_URL=
# SUPABASE_SERVICE_ROLE_KEY=
# OPENAI_API_KEY=
# OPENWEATHER_API_KEY=
